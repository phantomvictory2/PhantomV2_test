# ============================================================================
# Phantom V2 Production — environment template
# Copy to .env for local dev, or set these in Railway's Variables tab for prod.
# .env is gitignored. NEVER commit real values. NEVER paste POLY_PRIVATE_KEY anywhere but here/Railway.
# ============================================================================

# ── Feeds ───────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/
POLY_CLOB_API_URL=https://clob.polymarket.com

# ── Polymarket credentials (REGENERATE if ever exposed) ─────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=          # wallet signing key — Railway secret ONLY, never in chat/git
POLY_FUNDER_ADDRESS=      # deposit wallet address (0x...) that holds the USDC (the "funder")
SIGNATURE_TYPE=3         # 0=EOA, 1=email/Magic proxy, 2=Gnosis Safe, 3=POLY_1271 deposit-wallet
CHAIN_ID=137             # Polygon

# ── Database (DEDICATED prod Postgres — NOT the shared SaaS DB) ──────────
DATABASE_URL=

# ── Telegram alerts ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading mode & risk (live controls) ─────────────────────────────────
PAPER_MODE=true           # keep true until fee/slippage validation passes
KILL_SWITCH=false
PER_TRADE_USDC=10         # live validation size (start small)
MAX_CONCURRENT_USDC=30    # cap across all open positions
DAILY_LOSS_LIMIT_USDC=20  # auto-halt for the day if breached
ASSETS=BTC,ETH,SOL        # or BTC only to start
